rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Hypotheses collection rules
    match /hypos/{hypoId} {
      // Public read access
      allow read: if true;

      // Create: Must be signed in
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Update: Must be owner
      allow update: if isSignedIn() && isOwner(resource.data.ownerId);

      // Delete: Must be owner
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);

      // Runs subcollection
      match /runs/{runId} {
        // Public read access
        allow read: if true;

        // Create: Must be signed in
        allow create: if isSignedIn() && request.resource.data.runnerId == request.auth.uid;

        // Update own runs
        allow update: if isSignedIn() && isOwner(resource.data.runnerId);

        // Delete own runs
        allow delete: if isSignedIn() && isOwner(resource.data.runnerId);
      }
    }

    // Users collection for storing user profiles
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isSignedIn() && isOwner(userId);

      // Users can write their own profile
      allow write: if isSignedIn() && isOwner(userId);
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
